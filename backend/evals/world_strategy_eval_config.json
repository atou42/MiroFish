{
  "name": "world-strategy-eval",
  "description": "End-to-end world model strategy evaluation: preflight, actor smoke, resolver smoke, progression finalists, and repeated finals.",
  "preflight": {
    "health_timeout_s": 20,
    "json_timeout_s": 30,
    "json_probe_system": "Return a JSON object with keys ok, mode, score. Do not add any extra text.",
    "json_probe_user": "mode=world_eval_probe; score=1; ok=true"
  },
  "actor_smoke": {
    "description": "Single-tick actor sweep with a fixed balanced GPT-5.4 resolver.",
    "shared_max_rounds": 1,
    "shared_repeat_count": 1,
    "score_profile": "latency_smoke",
    "baseline_resolver_selector": "world_resolver_balanced",
    "shared_runtime_overrides": {
      "intent_agents_per_tick": 4,
      "intent_concurrency": 4,
      "resolver_cluster_size": 2,
      "resolver_cluster_concurrency": 2,
      "max_active_events": 4,
      "max_queued_events": 6,
      "max_event_duration_ticks": 3,
      "resolver_salvage_on_zero_accept": true,
      "provider_preflight_check": true,
      "provider_max_retries": 1,
      "actor_on_failure": "defer",
      "resolver_on_failure": "pause"
    }
  },
  "resolver_smoke": {
    "description": "Single-tick resolver sweep with the winning actor from actor smoke.",
    "shared_max_rounds": 1,
    "shared_repeat_count": 1,
    "score_profile": "latency_smoke",
    "shared_runtime_overrides": {
      "intent_agents_per_tick": 4,
      "intent_concurrency": 4,
      "resolver_cluster_size": 2,
      "resolver_cluster_concurrency": 2,
      "max_active_events": 4,
      "max_queued_events": 6,
      "max_event_duration_ticks": 3,
      "resolver_salvage_on_zero_accept": true,
      "provider_preflight_check": true,
      "provider_max_retries": 1,
      "actor_on_failure": "defer",
      "resolver_on_failure": "pause"
    }
  },
  "progression": {
    "description": "Three-tick finalist combo sweep for sustained world advancement.",
    "shared_max_rounds": 3,
    "shared_repeat_count": 1,
    "score_profile": "progression_mini",
    "top_actor_overall_count": 2,
    "top_actor_metric_winners": [
      "speed",
      "cleanliness"
    ],
    "top_resolver_overall_count": 3,
    "top_resolver_metric_winners": [
      "progression",
      "resilience"
    ],
    "combo_limit": 6,
    "shared_runtime_overrides": {
      "intent_agents_per_tick": 4,
      "intent_concurrency": 4,
      "resolver_cluster_size": 2,
      "resolver_cluster_concurrency": 2,
      "max_active_events": 4,
      "max_queued_events": 6,
      "max_event_duration_ticks": 2,
      "resolver_salvage_on_zero_accept": true,
      "provider_preflight_check": true,
      "provider_max_retries": 1,
      "actor_on_failure": "defer",
      "resolver_on_failure": "pause"
    }
  },
  "final_repeats": {
    "description": "Repeat the strongest progression finalists three times for stability.",
    "top_combo_count": 2,
    "repeat_count": 3
  },
