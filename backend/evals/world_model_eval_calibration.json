{
  "name": "world-model-calibration",
  "description": "Two-tick calibration suite for comparing selector quality once the world has enough time to branch and accumulate active events.",
  "shared_max_rounds": 2,
  "shared_rewrite_agent_selectors": true,
  "shared_run_limits": {
    "startup_timeout_seconds": 90,
    "stale_action_timeout_seconds": 300,
    "case_timeout_seconds": 900
  },
  "shared_runtime_overrides": {
    "intent_agents_per_tick": 5,
    "intent_concurrency": 5,
    "resolver_cluster_size": 2,
    "resolver_cluster_concurrency": 2,
    "max_active_events": 5,
    "max_queued_events": 8,
    "max_event_duration_ticks": 3,
    "resolver_salvage_on_zero_accept": true,
    "provider_preflight_check": true,
    "provider_max_retries": 1,
    "actor_on_failure": "defer",
    "resolver_on_failure": "pause"
  },
  "cases": [
    {
      "case_id": "baseline-fast-balanced",
      "label": "Baseline GPT-5.4 fast actor / balanced resolver",
      "actor_selector": "world_actor_fast",
      "resolver_selector": "world_resolver_balanced"
    },
    {
      "case_id": "balanced-balanced",
      "label": "GPT-5.4 balanced actor / balanced resolver",
      "actor_selector": "default_primary",
      "resolver_selector": "default_primary"
    },
    {
      "case_id": "fast-deep",
      "label": "GPT-5.4 fast actor / deep resolver",
      "actor_selector": "world_actor_fast",
      "resolver_selector": "world_report_deep"
    },
    {
      "case_id": "deep-balanced",
      "label": "GPT-5.4 deep actor / balanced resolver",
      "actor_selector": "world_report_deep",
      "resolver_selector": "world_resolver_balanced"
    },
    {
      "case_id": "alt-fast-fast",
      "label": "Alternate fast profile / alternate fast profile",
      "actor_selector": "parallel_secondary_fast",
      "resolver_selector": "parallel_secondary_fast"
    }
  ]
}
