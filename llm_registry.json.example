  "providers": {
    "custom_openai": {
      "api_key_env": "CUSTOM_OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1"
    }
  },
  "routes": {
    "default": "default_primary",
    "world_agent": "world_actor_fast",
    "world_resolver": "world_resolver_balanced",
    "world_profile": "world_actor_fast",
    "world_config": "world_resolver_balanced",
    "world_report": "world_report_deep",
    "ontology": "ontology_balanced",
    "report_agent": "report_agent_balanced",
    "zep_tools": "zep_tools_fast",
    "simulation_config": "simulation_config_balanced",
    "oasis_profile": "oasis_profile_balanced",
    "parallel_primary": "parallel_primary_balanced",
    "parallel_secondary": "parallel_secondary_fast",
    "twitter_agent": "twitter_agent_balanced",
    "reddit_agent": "reddit_agent_balanced"
  },
  "agent_selectors": {
    "world": {
      "default": "world_actor_fast",
      "by_entity_type": {
        "faction": "world_actor_fast",
        "character": "world_actor_fast",
        "organization": "world_actor_fast"
      }
    }
  }
