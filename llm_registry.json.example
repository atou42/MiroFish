    },
    "parallel_secondary_fast": {
      "openclaw_model": "codexvip/gpt-5.4",
      "speed_mode": "fast"
    },
    "eval_aliyun_qwen35_flash": {
      "openclaw_model": "aliyun-bailian/qwen3.5-flash"
    },
    "eval_aliyun_qwen35_plus": {
      "openclaw_model": "aliyun-bailian/qwen3.5-plus"
