# 推荐优先使用项目根目录的 llm_registry.json 管理 provider / profile / route。
# 这里保留的是 secret 与 legacy fallback。
LLM_REGISTRY_SOURCE=auto
LLM_REGISTRY_PATH=/absolute/path/to/MiroFish/llm_registry.json
OPENCLAW_CONFIG_PATH=/Users/yourname/.openclaw/openclaw.json

# LLM API配置（legacy fallback；OpenClaw / llm_registry.json 不可用时才会使用）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-5.4
LLM_SPEED_MODE=
LLM_REASONING_EFFORT=
LLM_VERBOSITY=
LLM_SERVICE_TIER=

# ===== World 模式专用模型（可选，未配置时回退到通用 LLM_*）=====
# actor 意图生成模型
WORLD_AGENT_LLM_API_KEY=
WORLD_AGENT_LLM_BASE_URL=
WORLD_AGENT_LLM_MODEL_NAME=
WORLD_AGENT_LLM_SPEED_MODE=fast
WORLD_AGENT_LLM_REASONING_EFFORT=
WORLD_AGENT_LLM_VERBOSITY=
WORLD_AGENT_LLM_SERVICE_TIER=

# world resolver / 并发事件裁决模型
WORLD_RESOLVER_LLM_API_KEY=
WORLD_RESOLVER_LLM_BASE_URL=
WORLD_RESOLVER_LLM_MODEL_NAME=
WORLD_RESOLVER_LLM_SPEED_MODE=balanced
WORLD_RESOLVER_LLM_REASONING_EFFORT=
WORLD_RESOLVER_LLM_VERBOSITY=
WORLD_RESOLVER_LLM_SERVICE_TIER=

# 每个 tick 的最大并发意图生成数
WORLD_INTENT_CONCURRENCY=6

# ===== World runtime 策略（严格固定模型，不做语义 fallback）=====
# true: world actor / resolver 必须保持各自模型身份，不允许偷偷换语义实现
WORLD_STRICT_MODEL_IDENTITY=true
# false: provider 或模型异常时不退回 heuristic / 其他语义路径
WORLD_ALLOW_SEMANTIC_FALLBACK=false
# 启动前先对 world agent / resolver 做健康检查
WORLD_PROVIDER_PREFLIGHT_CHECK=true
# 单次 LLM 调用最大重试次数（正式进入 waiting provider 之前）
WORLD_PROVIDER_MAX_RETRIES=3
# provider 不可用时，每次等待多久再做 health check / 重试
WORLD_PROVIDER_BACKOFF_SECONDS=5
# provider health check / chat 请求超时
WORLD_PROVIDER_HEALTHCHECK_TIMEOUT=15
# preflight 阶段 provider 异常时：wait=等待恢复，fail=直接失败
WORLD_RUN_ON_PROVIDER_DEGRADED=wait
# resolver 失败策略：pause=阻塞当前 tick，等待原 provider 恢复
WORLD_RESOLVER_ON_FAILURE=pause
# actor 失败策略：defer=延后该 actor 本 tick 意图，pause=等待恢复后重试
WORLD_ACTOR_ON_FAILURE=defer

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
